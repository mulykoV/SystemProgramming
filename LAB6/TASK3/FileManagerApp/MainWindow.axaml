<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FileManagerApp.MainWindow"
        Title="Arch File Explorer" Width="900" Height="600">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="5" Margin="0,0,0,10">
            <Button Content="⬅" Click="GoUp_Click"/>
            <TextBox Name="PathBox" Width="700" Text="/home/volodymyr"/>
            <Button Content="Оновити" Click="Refresh_Click"/>
        </StackPanel>

        <Grid ColumnDefinitions="300, *">
            <ListBox Name="FileListView" Grid.Column="0" DoubleTapped="FileListView_DoubleTapped"/>
            
            <ScrollViewer Grid.Column="1" Margin="10,0,0,0" Background="#f0f0f0">
                <TextBlock Name="FileContentView" TextWrapping="Wrap" FontFamily="Monospace" Padding="10"/>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>